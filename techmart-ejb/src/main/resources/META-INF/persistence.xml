<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="TechMart_Db_PU" transaction-type="JTA">

        <jta-data-source>jdbc/techmart_online_db</jta-data-source>

        <class>lk.dexter.techmart.entity.Cart</class>
        <class>lk.dexter.techmart.entity.CartItems</class>
        <class>lk.dexter.techmart.entity.Category</class>
        <class>lk.dexter.techmart.entity.Inventory</class>
        <class>lk.dexter.techmart.entity.Warehouse</class>
        <class>lk.dexter.techmart.entity.OrderItems</class>
        <class>lk.dexter.techmart.entity.Orders</class>
        <class>lk.dexter.techmart.entity.Product</class>
        <class>lk.dexter.techmart.entity.User</class>
        <class>lk.dexter.techmart.entity.NotificationType</class>
        <class>lk.dexter.techmart.entity.Notification</class>

        <properties>

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>

            <property name="hibernate.hbm2ddl.auto"
                      value="validate"/>

            <property name="hibernate.show_sql"
                      value="true"/>

            <property name="hibernate.format_sql"
                      value="true"/>

            <property name="hibernate.highlight_sql"
                      value="true"/>

            <property name="hibernate.use_sql_comments"
                      value="true"/>

            <property name="hibernate.jdbc.batch_size"
                      value="20"/>

            <property name="hibernate.order_inserts"
                      value="true"/>

            <property name="hibernate.order_updates"
                      value="true"/>

            <property name="hibernate.generate_statistics"
                      value="true"/>

            <property name="hibernate.bytecode.use_reflection_optimizer" value="false" />

            <property name="hibernate.jpa.compliance.proxy" value="true" />

        </properties>

    </persistence-unit>

</persistence>